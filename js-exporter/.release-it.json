{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "requireCleanWorkingDir": false,
    "requireBranch": "main",
    "requireUpstream": true,
    "requireCommits": true,
    "addUntrackedFiles": false,
    "commit": true,
    "commitMessage": "chore(js-exporter): release v${version} :rocket:",
    "tag": true,
    "tagName": "js-exporter-v${version}",
    "tagAnnotation": "JS Exporter v${version}",
    "push": true
  },
  "github": {
    "release": true,
    "releaseName": "JS Exporter v${version}",
    "autoGenerate": true,
    "preRelease": false,
    "draft": false,
    "tokenRef": "GITHUB_TOKEN",
    "skipChecks": false,
    "web": false,
    "assets": [
      "dist/script.min.js",
      "dist/bookmarklet.js",
      "dist/bookmarklet-loader.js",
      "dist/worker.js"
    ]
  },
  "npm": {
    "publish": false,
    "ignoreVersion": true,
    "allowSameVersion": true
  },
  "hooks": {
    "before:bump": "npm run build && npm test"
  }
}
